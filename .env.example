# DeepSeek API 配置（用于分析/演化 Agent）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Embedding 服务配置（用于向量化索引 + 语义检索）
# DeepSeek 不支持 embedding，需独立配置
# 方案一（推荐）: 硬基流动 - 免费额度多，模型全
#   https://siliconflow.cn 注册获取 API Key
EMBEDDING_API_KEY=your_siliconflow_api_key_here
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
# 方案二: OpenAI
# EMBEDDING_API_KEY=your_openai_api_key_here
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# 知识库路径
KNOWLEDGE_BASE_PATH=./knowledge_base

# 数据库路径
DB_PATH=./knowledge_base/db/knowledge.db

# 飞书配置（可选）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WIKI_SPACE_ID=

# 定时任务（cron 表达式，默认每天早上 8 点）
CRON_SCHEDULE=0 8 * * *

# 日志级别
LOG_LEVEL=info

# Web 服务器端口
WEB_PORT=3000
